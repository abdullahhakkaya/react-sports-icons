{
  "name": "@abdullahakkaya/sports-react-icons",
  "version": "0.1.0",
  "description": "React sports icon library generated from SVG assets",
  "author": "Abdullah Akkaya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abdullahhakkaya/sports-react-icons.git"
  },
  "homepage": "https://github.com/abdullahhakkaya/sports-react-icons#readme",
  "bugs": {
    "url": "https://github.com/abdullahhakkaya/sports-react-icons/issues"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "generate": "node scripts/generate-icons.mjs",
